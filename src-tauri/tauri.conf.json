{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Snow Devil",
  "version": "0.1.0",
  "identifier": "com.watts.github-graph-browser",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Snow Devil",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset:; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: https://avatars.githubusercontent.com data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; object-src 'none'; base-uri 'self'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/martian7777/Snow-Devil/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFDQTA4RkQyRjQxM0JGQjcKUldTM3Z4UDAwbytnckMzKzh0WWlNY1J2MkNqM29vYklVYmZJcUJYaytrb2xYM1ZzMXowT1Fmdk0K"
    }
  }
}
